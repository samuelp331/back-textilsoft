DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=.onrender.com

# Example:
# DATABASE_URL=postgresql://user:password@host:5432/database
# DATABASE_URL=mysql://user:password@host:3306/database
DATABASE_URL=

# Frontend production URL, for example:
# CORS_ALLOWED_ORIGINS=https://textilsoft-frontend.onrender.com
CORS_ALLOWED_ORIGINS=

# Required if you use cookie/session-authenticated POSTs from the frontend.
# Example:
# CSRF_TRUSTED_ORIGINS=https://textilsoft-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=

# URL used by password reset links.
# Example:
# PASSWORD_RESET_FRONTEND_URL=https://textilsoft-frontend.onrender.com
PASSWORD_RESET_FRONTEND_URL=
